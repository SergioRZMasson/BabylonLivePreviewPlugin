{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-x64-debug",
      "displayName": "Windows x64 Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NAPI_JAVASCRIPT_ENGINE": "V8",
        "GRAPHICS_API": "D3D11"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NAPI_JAVASCRIPT_ENGINE": "V8",
        "GRAPHICS_API": "D3D11"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS arm64 (Apple Silicon)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "NAPI_JAVASCRIPT_ENGINE": "JavaScriptCore",
        "GRAPHICS_API": "Metal",
        "BLP_BUILD_MAX": "OFF",
        "BLP_BUILD_MAYA": "OFF"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    }
  ],
  "buildPresets": [
    { "name": "windows-x64-debug",   "configurePreset": "windows-x64-debug",   "configuration": "Debug" },
    { "name": "windows-x64-release", "configurePreset": "windows-x64-release", "configuration": "Release" },
    { "name": "macos-arm64",         "configurePreset": "macos-arm64" }
  ]
}
